# (  Don't display this item on the M map
# ?  Automatically identify this item

#########################################
# Consumables
#########################################
# ?:[EQU $CLASS Mage High-Mage Sorcerer Blue-Mage Mirror-Master Elementalist]
# github.com/gg5074/configs/blob/main/hengband_picktype.prf

~ration of food
~elvish waybread

mushroom of restoring#!E
~mushroom of hallucination

?:[EQU $RACE Snotling Doppelganger]
~?unidentified items:mushroom
~mushroom
?:1

!mushroom of sickness
!mushroom of disease
!mushroom of confusion

~identified items:mushroom
~unidentified items:mushroom

?:[LEQ $LEVEL 35]
potions:resist heat and cold#!kq
?:1

potions:resistance#!kq
potions:stone skin#!k
potions:heroism
potions:speed#!kq
potions:giant strength#!k

potions:enlightenment

potions:of strength#!k
potions:of intelligence#!k
potions:of wisdom#!k
potions:of dexterity#!k
potions:of constitution#!k
potions:of charisma#!k
potions:augmentation#!k

potions:experience
potions:polymorph#!k
potions:new life#!**
potions:self knowledge#!k

potions:curing
potions:of healing#!kq
potions:of life#!kq
potions:of *healing*#!kq
potions:restore mana#!kq

~potions:salt water

!potions:tsuyoshi special
!scrolls:identify

identified items:potions
unidentified items:potions

?:[NOT [EQU $CLASS Berserker]]
scrolls:artifact creation#!*
scrolls:of destruction#!*
scrolls:mass genocide#!*
scrolls:genocide#!*
scrolls:forest creation
scrolls:wall of stone
scrolls:acquirement#!*
scrolls:banish
