# Control-Keypad (lib/pref/pref-mac.prf) -- wield {@0} and tunnel
# T:KP_0:18
# T:KP_9:28
# A:\e\ew0\s\s\\+1
# P:^_CO19\r

# Control-Keypad-Zero -- wield {@0}
# A:\e\ew0\s
# P:^_CO18\r

~shovel#@w0
~pickaxe#@w0

