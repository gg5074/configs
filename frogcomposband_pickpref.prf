A:\e\eUa
P:\[F1]
A:\e\eUb
P:\[F2]
A:\e\eUc
P:\[F3]

A:\e\eUd*5
P:\[F4]
A:\e\eUe*5
P:\[F5]
A:\e\eUf*5
P:\[F6]

A:\e\eUg*5
P:\[F7]
A:\e\eUh*5
P:\[F8]
A:\e\eUi*5
P:\[F9]
A:\e\eJj
P:\[F10]
A:\e\eJk
