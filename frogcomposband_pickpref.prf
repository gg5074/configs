#
#*** キーマップ定義
#
# [\e]は[Esc]、[\r]は[Enter]、[\t]は[Tab]、[\s]は[スペース]、[^]は[Ctrl]、[\]キーは[\\]、[^]は[\^]
# yasd.fans/frogcomposbandhelpfile/command#OriginalKeyset
#
# 使っていないCtrlキー: B ,C, L, N, Y, Z
#

# [Space]: スペースキーで[Esc][Esc][Esc]
A:\e\e\e
C:0:\s

# [Enter]: Enterキーでインベントリ
A:\e\ei
C:0:\r

# [#]: キャラクターシート、Dumpを出力
A:\e\eC|\r
C:0:#

# [:]: キャラクターシート、Resistances/Abilities（Take notesの[:]に上書き）
A:\e\eCr
C:0::

# [$]: キャラクターシート、Home（Reload Mogaminator prefsの[$]に上書き）
A:\e\eCh
C:0:$

# [_]: ペットの維持費（Edit/activate Mogaminator prefsの[_]に上書き）
A:\e\e~p
C:0:_

# [x]: モンスターを見る
#A:\e\e*r
A:\e\el+r
C:0:x

# 回復するまで休む
A:\e\eR\r
C:0:\[shift-KP_5]

# ターンを進める（Inscribe an objectの[Z]に上書き）
A:\e\eR15\r
C:0:Z

# [,]: Travel to location（Stay stillの[,]に上書き）
A:\e\e`
C:0:,

# トラベルを再開（Jam a doorの[j]に上書き）
A:\e\eJ
C:0:j

# トラベル、Home
A:\e\e]hJ
C:0:^H

# トラベル、階段<
A:\e\e`<
C:0:^U

# トラベル、階段>
A:\e\e`>
C:0:^D

# [.]: Travel to interesting item（Runの[.]に上書き）
A:\e\eH
C:0:.

# [@]: Auto-Get nearby objects（Interact with macrosの[@]に上書き）
A:\e\e^G
C:0:@

# [Tab]: 近づく、攻撃する
A:\e\e;*5
C:0:\t



#
# 射撃
#

?:[EQU $CLASS Archer]
# [h]: スロットa
A:\e\efa*5
C:0:h
# [y]: スロットb
A:\e\efb*5
C:0:y
# [']: スロットc（Playback recorded commandの[']に上書き）
A:\e\efc*5
C:0:'
# [(]: スロットd
A:\e\efd*5
C:0:(
# [)]: スロットe（Create screen dumpの[)]に上書き）
A:\e\efe*5
C:0:)
?:1



#
# 攻撃呪文
# nikheizen.github.io/pages/spellbooks.html
#

#
# Armageddon:
# Book of Elements
# Earth, Wind and Fire
# Path of Destruction
#

?:[EQU $REALM1 Armageddon]
# [h]: Lightning Bolt
A:\e\emaa*5
C:0:h
# [y]: Lightning Ball
A:\e\emae*5
C:0:y
# [']: Shard Bolt,
A:\e\emba*5
C:0:'
# [(]: Water Ball
A:\e\emccb*5
C:0:(
# [)]: Breathe Lightning
A:\e\emcc*5
C:0:)
?:1



#
# 補助呪文
#

#
# Sorcery:
# Beginner's Handbook
# Master Sorcerer's Hand Profic
# Pattern Sorcery
#

?:[EQU $REALM2 Sorcery]
# Detect Monsters
A:\e\emea
C:0:X
# Phase Door
A:\e\emeb
C:0:P
# Detect Doors and Traps
A:\e\emec
C:0:K

# Light Area
A:\e\emed
C:0:Y
# Confuse Monster
A:\e\emee*
C:0:N
# Teleport
A:\e\emef
C:0:O

# Magic Mapping
A:\e\emfa
C:0:^R
# Teleport Away
A:\e\emfe*
C:0:^A
# Haste Self
A:\e\emff
C:0:^O
# Identify True
A:\e\emfg
C:0:^I

# Stair Creation
A:\e\emga
C:0:^K
# Sense Minds
A:\e\emge*
C:0:^E
# Teleport to Town
A:\e\emgf
C:0:^J
# Word of Recall
A:\e\emgg
C:0:^R
# Dimension Door
A:\e\emgg
C:0:^M
?:1



#
#*** マクロ
#

# 縦横に17、斜めに12移動（*破壊*の杖の範囲: 縦横は距離13-17、斜めは最大12）
A:22222222222222222
P:\[alt-KP_2]
A:44444444444444444
P:\[alt-KP_4]
A:66666666666666666
P:\[alt-KP_6]
A:88888888888888888
P:\[alt-KP_8]
P:111111111111
P:\[alt-KP_1]
P:333333333333
P:\[alt-KP_3]
P:777777777777
P:\[alt-KP_7]
A:999999999999
P:\[alt-KP_9]

